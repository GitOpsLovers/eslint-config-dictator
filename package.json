{
  "name": "@gitopslovers/eslint-config-multistack",
  "version": "0.0.0-development",
  "description": "An ESLint plugin that provides opinionated preset configurations for multiple frameworks and libraries.",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "preset",
    "angular",
    "react",
    "express",
    "dictator"
  ],
  "homepage": "https://github.com/GitOpsLovers/eslint-config-dictator#readme",
  "bugs": {
    "url": "https://github.com/GitOpsLovers/eslint-config-dictator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitOpsLovers/eslint-config-dictator.git"
  },
  "license": "MIT",
  "author": "GitOps Lovers",
  "main": "index.mjs",
  "files": [
    "index.mjs",
    "lib/**/*.mjs"
  ],
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitest/eslint-plugin": "1.6.17",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-testing-library": "7.16.2"
  },
  "peerDependencies": {
    "eslint": ">=10.3.0",
    "globals": ">=17.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "semantic-release": "25.0.3",
    "vitest": "4.1.6"
